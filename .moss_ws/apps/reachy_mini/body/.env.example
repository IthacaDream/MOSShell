# Reachy Mini Body App — 环境变量
# 复制此文件为 .env 并修改为你的本地配置

# ---- Python 运行时 ----
# Python 3.13 动态库 (GStreamer Python plugin 依赖)
DYLD_LIBRARY_PATH=/opt/homebrew/Caskroom/miniconda/base/lib

# ---- GStreamer (pip 安装的预编译包) ----
# 所有 GStreamer 组件都在 app venv 的 gstreamer_libs 目录下
GST_PLUGIN_PATH=.venv/lib/python3.13/site-packages/gstreamer_libs/lib/gstreamer-1.0
GI_TYPELIB_PATH=.venv/lib/python3.13/site-packages/gstreamer_libs/lib/girepository-1.0
GST_PLUGIN_SCANNER=.venv/lib/python3.13/site-packages/gstreamer_libs/libexec/gstreamer-1.0/gst-plugin-scanner
GST_REGISTRY=runtime/gstreamer/registry.bin

# ---- MOSS 运行时 (由 host 注入, 此处为手动调试用) ----
# MOSS_WORKSPACE=
# MOSS_CELL_ADDRESS=app/reachy_mini/body
# MOSS_SESSION_SCOPE=default
# MOSS_MODE_NAME=default
